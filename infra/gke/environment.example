# Locust POC Lab — GKE Practice Cluster Configuration
# Copy this file to infra/gke/environment and customize as needed.
# Example: cp infra/gke/environment.example infra/gke/environment
#
# Rough cost estimate for the defaults below (zonal cluster in us-central1):
# - 3 x e2-standard-4 worker nodes plus 100 GB pd-balanced disks each
# - roughly $0.45-$0.75/hour before network egress or other add-ons
# Delete the cluster when finished to avoid ongoing charges: make gke-down

GKE_CLUSTER_NAME=locust-poc-lab
GKE_ZONE=us-central1-a
# GKE_REGION=us-central1

GKE_NODE_COUNT=3
GKE_MACHINE_TYPE=e2-standard-4
GKE_DISK_SIZE_GB=100
GKE_DISK_TYPE=pd-balanced
GKE_RELEASE_CHANNEL=regular

GKE_NETWORK=default
GKE_SUBNETWORK=default