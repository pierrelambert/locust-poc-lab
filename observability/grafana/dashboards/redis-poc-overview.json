{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Throughput (ops/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{topology=~\"$topology\"}[1m])",
          "legendFormat": "{{topology}} ops/sec (server)",
          "refId": "A"
        },
        {
          "expr": "locust_requests_current_rps",
          "legendFormat": "Locust RPS (client)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "locust_requests_avg_response_time",
          "legendFormat": "p50 (avg)",
          "refId": "A"
        },
        {
          "expr": "locust_requests_current_response_time_percentile_95",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "locust_requests_current_response_time_percentile_99",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "locust_requests_current_fail_per_sec",
          "legendFormat": "Errors/sec (client)",
          "refId": "A"
        },
        {
          "expr": "rate(redis_rejected_connections_total{topology=~\"$topology\"}[1m])",
          "legendFormat": "{{topology}} rejected conn/sec",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} used memory",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} max memory",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_connected_clients{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} connected clients",
          "refId": "A"
        },
        {
          "expr": "redis_blocked_clients{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} blocked clients",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_replication_backlog_bytes{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} repl backlog",
          "refId": "A"
        },
        {
          "expr": "redis_connected_slaves{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} connected replicas",
          "refId": "B"
        },
        {
          "expr": "redis_replica_repl_offset{topology=~\"$topology\"}",
          "legendFormat": "{{topology}} replica offset",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["redis", "poc-lab"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(redis_up, topology)",
        "hide": 0,
        "includeAll": true,
        "label": "Topology",
        "multi": true,
        "name": "topology",
        "query": { "query": "label_values(redis_up, topology)", "refId": "topology" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Scenario",
        "name": "scenario",
        "options": [],
        "query": "",
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Run ID",
        "name": "run_id",
        "options": [],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Redis POC Lab — Overview",
  "uid": "redis-poc-overview",
  "version": 1
}
